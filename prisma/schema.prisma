generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  BROKER    @map("broker")
  PROVIDER  @map("provider")
  ADMIN     @map("admin")

  @@map("user_role")
}

enum TripStatus {
  PENDING           @map("pending")
  ASSIGNED          @map("assigned")
  ACCEPTED          @map("accepted")
  REJECTED          @map("rejected")
  DRIVER_EN_ROUTE   @map("driver_en_route")
  PASSENGER_PICKED_UP @map("passenger_picked_up")
  COMPLETED         @map("completed")
  CANCELLED         @map("cancelled")
  NO_SHOW           @map("no_show")

  @@map("trip_status")
}

enum MobilityType {
  AMBULATORY  @map("ambulatory")
  WHEELCHAIR  @map("wheelchair")
  STRETCHER   @map("stretcher")

  @@map("mobility_type")
}

enum CredentialType {
  BUSINESS_LICENSE    @map("business_license")
  INSURANCE_COI       @map("insurance_coi")
  VEHICLE_INSPECTION  @map("vehicle_inspection")
  BACKGROUND_CHECK    @map("background_check")
  DRUG_TEST           @map("drug_test")
  CPR_CERTIFICATION   @map("cpr_certification")
  HIPAA_TRAINING      @map("hipaa_training")
  FWA_TRAINING        @map("fwa_training")
  ADA_TRAINING        @map("ada_training")
  DRIVERS_LICENSE     @map("drivers_license")
  OIG_SCREENING       @map("oig_screening")
  SAM_SCREENING       @map("sam_screening")
  OTHER               @map("other")

  @@map("credential_type")
}

enum CredentialStatus {
  VALID     @map("valid")
  EXPIRING  @map("expiring")
  EXPIRED   @map("expired")
  PENDING   @map("pending")
  REJECTED  @map("rejected")

  @@map("credential_status")
}

enum ComplaintStatus {
  OPEN          @map("open")
  INVESTIGATING @map("investigating")
  RESOLVED      @map("resolved")
  CLOSED        @map("closed")

  @@map("complaint_status")
}

enum ComplaintCategory {
  LATE_PICKUP       @map("late_pickup")
  NO_SHOW_DRIVER    @map("no_show_driver")
  VEHICLE_CONDITION @map("vehicle_condition")
  DRIVER_BEHAVIOR   @map("driver_behavior")
  BILLING           @map("billing")
  ACCESSIBILITY     @map("accessibility")
  SAFETY            @map("safety")
  OTHER             @map("other")

  @@map("complaint_category")
}

enum ReimbursementFormType {
  MEDICAID_TRIP    @map("medicaid_trip")
  PROVIDER_INVOICE @map("provider_invoice")
  CMS_1500         @map("cms_1500")

  @@map("reimbursement_form_type")
}

enum ReimbursementFormStatus {
  DRAFT        @map("draft")
  SUBMITTED    @map("submitted")
  UNDER_REVIEW @map("under_review")
  APPROVED     @map("approved")
  DENIED       @map("denied")
  PAID         @map("paid")
  VOID         @map("void")

  @@map("reimbursement_form_status")
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                UserRole  @default(BROKER)
  providerId          String?   @map("provider_id")
  provider            Provider? @relation(fields: [providerId], references: [id])
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  createdTrips  Trip[]              @relation("TripCreator")
  statusChanges TripStatusHistory[]
  notes         Note[]
  createdReimbursementForms  ReimbursementForm[] @relation("FormCreator")
  reviewedReimbursementForms ReimbursementForm[] @relation("FormReviewer")

  @@map("users")
}

model Provider {
  id           String         @id @default(cuid())
  code         String         @unique
  name         String
  contactName  String         @map("contact_name")
  phone        String
  email        String
  serviceAreas String[]       @map("service_areas")
  vehicleTypes MobilityType[] @map("vehicle_types")
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  // Relations
  users              User[]
  trips              Trip[]
  credentials        ProviderCredential[]
  complaints         Complaint[]
  reimbursementForms ReimbursementForm[]

  @@map("providers")
}

model Trip {
  id                  String       @id @default(cuid())
  tripNumber          String       @unique @map("trip_number")
  patientName         String       @map("patient_name")
  patientPhone        String       @map("patient_phone")
  pickupAddress       String       @map("pickup_address")
  destinationAddress  String       @map("destination_address")
  appointmentDate     DateTime     @map("appointment_date")
  appointmentTime     String       @map("appointment_time")
  mobilityType        MobilityType @map("mobility_type")
  specialInstructions String       @default("") @map("special_instructions")
  status              TripStatus   @default(PENDING)
  providerId          String?      @map("provider_id")
  provider            Provider?    @relation(fields: [providerId], references: [id])
  createdById         String       @map("created_by_id")
  createdBy           User         @relation("TripCreator", fields: [createdById], references: [id])
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  // Trip documentation fields (required for compliance)
  medicaidId          String?      @map("medicaid_id")
  authorizationNumber String?      @map("authorization_number")
  driverName          String?      @map("driver_name")
  driverId            String?      @map("driver_id")
  vehicleId           String?      @map("vehicle_id")
  actualPickupTime    DateTime?    @map("actual_pickup_time")
  actualDropoffTime   DateTime?    @map("actual_dropoff_time")
  actualMileage       Float?       @map("actual_mileage")
  memberSignatureUrl  String?      @map("member_signature_url")

  // Standing order reference
  standingOrderId     String?      @map("standing_order_id")
  standingOrder       StandingOrder? @relation(fields: [standingOrderId], references: [id])

  // Relations
  statusHistory      TripStatusHistory[]
  notes              Note[]
  complaints         Complaint[]
  reimbursementForms ReimbursementForm[]

  @@map("trips")
}

model TripStatusHistory {
  id          String     @id @default(cuid())
  tripId      String     @map("trip_id")
  trip        Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  status      TripStatus
  note        String?
  changedById String     @map("changed_by_id")
  changedBy   User       @relation(fields: [changedById], references: [id])
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("trip_status_history")
}

model Note {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  content   String
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notes")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userId     String   @map("user_id")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ─── Provider Credentialing ─────────────────────────────

model ProviderCredential {
  id              String           @id @default(cuid())
  providerId      String           @map("provider_id")
  provider        Provider         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  type            CredentialType
  status          CredentialStatus @default(PENDING)
  documentNumber  String?          @map("document_number")
  issuedDate      DateTime?        @map("issued_date")
  expirationDate  DateTime?        @map("expiration_date")
  verifiedById    String?          @map("verified_by_id")
  verifiedAt      DateTime?        @map("verified_at")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("provider_credentials")
}

// ─── Complaint Tracking ─────────────────────────────────

model Complaint {
  id              String            @id @default(cuid())
  complaintNumber String            @unique @map("complaint_number")
  category        ComplaintCategory
  status          ComplaintStatus   @default(OPEN)
  description     String
  resolution      String?
  providerId      String?           @map("provider_id")
  provider        Provider?         @relation(fields: [providerId], references: [id])
  tripId          String?           @map("trip_id")
  trip            Trip?             @relation(fields: [tripId], references: [id])
  reportedBy      String            @map("reported_by")
  resolvedById    String?           @map("resolved_by_id")
  resolvedAt      DateTime?         @map("resolved_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("complaints")
}

// ─── Standing Orders (Recurring Trips) ──────────────────

model StandingOrder {
  id                  String       @id @default(cuid())
  patientName         String       @map("patient_name")
  patientPhone        String       @map("patient_phone")
  medicaidId          String?      @map("medicaid_id")
  pickupAddress       String       @map("pickup_address")
  destinationAddress  String       @map("destination_address")
  appointmentTime     String       @map("appointment_time")
  mobilityType        MobilityType @map("mobility_type")
  specialInstructions String       @default("") @map("special_instructions")
  providerId          String?      @map("provider_id")
  // Recurrence
  daysOfWeek          Int[]        @map("days_of_week") // 0=Sun, 1=Mon, ... 6=Sat
  startDate           DateTime     @map("start_date")
  endDate             DateTime?    @map("end_date")
  active              Boolean      @default(true)
  createdById         String       @map("created_by_id")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  // Relations
  trips Trip[]

  @@map("standing_orders")
}

// ─── Reimbursement Forms ────────────────────────────────

model ReimbursementForm {
  id         String                  @id @default(cuid())
  formNumber String                  @unique @map("form_number")
  formType   ReimbursementFormType   @map("form_type")
  status     ReimbursementFormStatus @default(DRAFT)

  // Linked entities
  tripId     String?  @map("trip_id")
  trip       Trip?    @relation(fields: [tripId], references: [id])
  providerId String?  @map("provider_id")
  provider   Provider? @relation(fields: [providerId], references: [id])
  createdById  String   @map("created_by_id")
  createdBy    User     @relation("FormCreator", fields: [createdById], references: [id])
  reviewedById String?  @map("reviewed_by_id")
  reviewedBy   User?    @relation("FormReviewer", fields: [reviewedById], references: [id])

  // Workflow timestamps
  submittedAt DateTime? @map("submitted_at")
  reviewedAt  DateTime? @map("reviewed_at")
  paidAt      DateTime? @map("paid_at")
  reviewNotes String?   @map("review_notes")
  totalAmount Float     @default(0) @map("total_amount")

  // ── Medicaid Trip Reimbursement fields ──
  patientName         String?  @map("patient_name")      // encrypted
  patientDob          String?  @map("patient_dob")       // encrypted
  medicaidId          String?  @map("medicaid_id")
  authorizationNumber String?  @map("authorization_number")
  healthPlanName      String?  @map("health_plan_name")
  healthPlanId        String?  @map("health_plan_id")
  pickupAddress       String?  @map("pickup_address")
  destinationAddress  String?  @map("destination_address")
  tripDate            DateTime? @map("trip_date")
  pickupTime          String?  @map("pickup_time")
  dropoffTime         String?  @map("dropoff_time")
  mobilityType        MobilityType? @map("mobility_type")
  mileage             Float?
  mileageRate         Float?   @map("mileage_rate")
  baseRate            Float?   @map("base_rate")
  tolls               Float?
  waitTime            Int?     @map("wait_time")         // minutes
  waitTimeRate        Float?   @map("wait_time_rate")
  driverName          String?  @map("driver_name")
  driverId            String?  @map("driver_id")
  vehicleId           String?  @map("vehicle_id")
  vehicleType         String?  @map("vehicle_type")
  memberSignatureUrl  String?  @map("member_signature_url")
  driverSignatureUrl  String?  @map("driver_signature_url")
  attendantName       String?  @map("attendant_name")
  returnTrip          Boolean? @map("return_trip")
  tripPurpose         String?  @map("trip_purpose")

  // ── Provider Invoice fields ──
  invoiceNumber       String?  @map("invoice_number")
  invoiceDate         DateTime? @map("invoice_date")
  billingPeriodStart  DateTime? @map("billing_period_start")
  billingPeriodEnd    DateTime? @map("billing_period_end")
  providerTaxId       String?  @map("provider_tax_id")
  providerNpi         String?  @map("provider_npi")
  remitToName         String?  @map("remit_to_name")
  remitToAddress      String?  @map("remit_to_address")
  paymentTerms        String?  @map("payment_terms")

  // ── CMS-1500 fields (Boxes 1-33) ──
  insuranceType         String?  @map("insurance_type")           // Box 1
  insuredIdNumber       String?  @map("insured_id_number")        // Box 1a
  patientSex            String?  @map("patient_sex")              // Box 3
  insuredName           String?  @map("insured_name")             // Box 4 (encrypted)
  patientAddress        String?  @map("patient_address")          // Box 5
  patientCity           String?  @map("patient_city")
  patientState          String?  @map("patient_state")
  patientZip            String?  @map("patient_zip")
  patientPhone          String?  @map("patient_phone")            // encrypted
  patientRelToInsured   String?  @map("patient_rel_to_insured")   // Box 6
  insuredAddress        String?  @map("insured_address")          // Box 7
  insuredCity           String?  @map("insured_city")
  insuredState          String?  @map("insured_state")
  insuredZip            String?  @map("insured_zip")
  patientConditionRelTo String?  @map("patient_condition_rel_to") // Box 10
  insuredPolicyGroup    String?  @map("insured_policy_group")     // Box 11
  insuredDob            String?  @map("insured_dob")              // Box 11a
  insuredSex            String?  @map("insured_sex")              // Box 11a
  insuredPlanName       String?  @map("insured_plan_name")        // Box 11c
  patientSignatureOnFile Boolean? @map("patient_sig_on_file")     // Box 12
  insuredSignatureOnFile Boolean? @map("insured_sig_on_file")     // Box 13
  conditionDateOfOnset  DateTime? @map("condition_date_of_onset") // Box 14
  referringProviderName String?  @map("referring_provider_name")  // Box 17
  referringProviderNpi  String?  @map("referring_provider_npi")   // Box 17b
  diagnosisCode1        String?  @map("diagnosis_code_1")         // Box 21
  diagnosisCode2        String?  @map("diagnosis_code_2")
  diagnosisCode3        String?  @map("diagnosis_code_3")
  diagnosisCode4        String?  @map("diagnosis_code_4")
  priorAuthNumber       String?  @map("prior_auth_number")        // Box 23
  federalTaxId          String?  @map("federal_tax_id")           // Box 25
  federalTaxIdType      String?  @map("federal_tax_id_type")      // SSN or EIN
  patientAccountNumber  String?  @map("patient_account_number")   // Box 26
  acceptAssignment      Boolean? @map("accept_assignment")        // Box 27
  amountPaid            Float?   @map("amount_paid")              // Box 29
  billingProviderName   String?  @map("billing_provider_name")    // Box 33
  billingProviderAddress String? @map("billing_provider_address")
  billingProviderNpi    String?  @map("billing_provider_npi")     // Box 33a
  billingProviderTaxonomy String? @map("billing_provider_taxonomy") // Box 33b
  facilityName          String?  @map("facility_name")            // Box 32
  facilityAddress       String?  @map("facility_address")
  facilityNpi           String?  @map("facility_npi")             // Box 32a

  // Public submission fields (no login required)
  submitterName      String?  @map("submitter_name")
  submitterEmail     String?  @map("submitter_email")
  submitterPhone     String?  @map("submitter_phone")
  isPublicSubmission Boolean  @default(false) @map("is_public_submission")

  // Relations
  serviceLines CMS1500ServiceLine[]
  invoiceLines ProviderInvoiceLine[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reimbursement_forms")
}

model CMS1500ServiceLine {
  id                 String   @id @default(cuid())
  formId             String   @map("form_id")
  form               ReimbursementForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  lineNumber         Int      @map("line_number")
  dateOfServiceFrom  DateTime @map("date_of_service_from")
  dateOfServiceTo    DateTime @map("date_of_service_to")
  placeOfService     String   @map("place_of_service")
  procedureCode      String   @map("procedure_code")
  modifiers          String[] @default([])
  diagnosisPointer   String   @map("diagnosis_pointer")
  charges            Float
  units              Float    @default(1)
  renderingProviderNpi String? @map("rendering_provider_npi")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("cms1500_service_lines")
}

model ProviderInvoiceLine {
  id                 String   @id @default(cuid())
  formId             String   @map("form_id")
  form               ReimbursementForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  lineNumber         Int      @map("line_number")
  tripId             String?  @map("trip_id")
  tripNumber         String?  @map("trip_number")
  serviceDate        DateTime @map("service_date")
  serviceDescription String   @map("service_description")
  pickupAddress      String?  @map("pickup_address")
  destinationAddress String?  @map("destination_address")
  mileage            Float?
  rate               Float
  amount             Float
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("provider_invoice_lines")
}
